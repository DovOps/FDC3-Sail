{
  "name": "@finos/fdc3-sail",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "clean": "npm run clean --workspaces",
    "build": "npm run build --workspaces --if-present",
    "web:dev": "npm run dev -w packages/web",
    "electron:start": "npm run dev -w packages/electron",
    "examples:dev": "npm run dev -w packages/fdc3-example-apps",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "start": "concurrently -n \"WEB,ELECTRON,EXAMPLES\" -c \"blue,green,yellow\" \"npm run web:dev\" \"wait-on -l -i 1000 -t 60000 -w 1000 tcp:localhost:8090 && npm run electron:start\" \"npm run examples:dev\""
  },
  "workspaces": [
    "packages/da-impl",
    "packages/common",
    "packages/web",
    "packages/electron",
    "packages/fdc3-example-apps"
  ],
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.4.1",
    "tsx": "^4.19.1",
    "nodemon": "^3.1.9"
  },
  "dependencies": {
    "real-require": "^1.0.0",
    "wait-on": "^8.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "vite-express": "^0.22.1"
  }
}
